{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "graphify-out/**",
    "apps/landing/out/**",
    "apps/landing/.next/**",
    "apps/landing/public/**",
    "apps/landing/src/content/**"
  ],
  "ignoreBinaries": ["claude"],
  "ignoreDependencies": [
    "semantic-release",
    "@semantic-release/exec",
    "@semantic-release/github",
    "conventional-changelog-conventionalcommits",
    "@commitlint/types"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{js,mjs}",
        ".claude/hooks/*.mjs",
        "eslint.a11y.config.mjs",
        "lostpixel.config.ts"
      ]
    },
    "apps/desktop": {
      "entry": ["src/renderer/main.tsx", "src/e2e-main.tsx"]
    },
    "apps/extension": {
      "entry": ["src/background.ts"]
    },
    "apps/landing": {
      "entry": [
        "next.config.ts",
        "vitest.config.ts",
        "src/app/**/{page,layout,not-found,error,route}.{ts,tsx}"
      ]
    },
    "packages/translations": {
      "entry": ["i18next.config.ts"]
    }
  }
}
