{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["graphify-out/**", "landing/**"],
  "ignoreBinaries": ["rtk", "claude"],
  "ignoreDependencies": [
    "semantic-release",
    "@semantic-release/exec",
    "@semantic-release/github",
    "conventional-changelog-conventionalcommits",
    "@commitlint/types"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/*.{js,mjs}",
        ".claude/hooks/*.mjs",
        "eslint.a11y.config.mjs",
        "lostpixel.config.ts"
      ]
    },
    "apps/desktop": {
      "entry": ["src/renderer/main.tsx", "src/e2e-main.tsx"]
    },
    "apps/landing": {
      "entry": ["src/app/**/{page,layout}.tsx", "scripts/*.mjs"],
      // GL stack installed at PR0 scaffold but consumed milestone by milestone;
      // remove each as it is first imported (ripbook M1-M6).
      "ignoreDependencies": [
        "three",
        "@react-three/fiber",
        "@react-three/drei",
        "postprocessing",
        "troika-three-text",
        "gsap",
        "lenis",
        "zustand",
        "framer-motion",
        "@types/three",
        "svg-path-properties"
      ]
    },
    "apps/extension": {
      "entry": ["src/background.ts"]
    },
    "packages/translations": {
      "entry": ["i18next.config.ts"]
    }
  }
}
