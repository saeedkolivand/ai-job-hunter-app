{
  "name": "@ajh/prompts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./generate": {
      "types": "./src/generate.ts",
      "default": "./dist/generate.js"
    },
    "./analyze": {
      "types": "./src/analyze.ts",
      "default": "./dist/analyze.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
