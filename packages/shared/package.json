{
  "name": "@ajh/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ipc": {
      "types": "./src/ipc/contracts/index.ts",
      "default": "./dist/ipc/contracts.js"
    },
    "./language-detection": {
      "types": "./src/language-detection.ts",
      "default": "./dist/language-detection.js"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./dist/schemas/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./src/utils.ts",
      "default": "./dist/utils.js"
    },
    "./ai-models": {
      "types": "./src/ai-models.ts",
      "default": "./dist/ai-models.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "franc": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
