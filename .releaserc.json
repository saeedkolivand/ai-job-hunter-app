{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "ui", "release": "patch" },
          { "type": "revert", "release": "patch" },
          { "type": "refactor", "release": false },
          { "type": "docs", "release": false },
          { "type": "style", "release": false },
          { "type": "test", "release": false },
          { "type": "build", "release": false },
          { "type": "ci", "release": false },
          { "type": "chore", "release": false },
          { "breaking": true, "release": "major" }
        ]
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits",
        "presetConfig": {
          "types": [
            { "type": "feat", "section": "âś¨ Features", "hidden": false },
            { "type": "fix", "section": "í°› Bug Fixes", "hidden": false },
            { "type": "perf", "section": "âšˇ Performance", "hidden": false },
            { "type": "ui", "section": "íľ¨ UI/UX", "hidden": false },
            { "type": "refactor", "section": "â™»ď¸Ź Refactors", "hidden": false },
            { "type": "docs", "section": "íłš Documentation", "hidden": false },
            { "type": "build", "section": "í´§ Build System", "hidden": true },
            { "type": "ci", "section": "í±· CI", "hidden": true },
            { "type": "test", "section": "âś… Tests", "hidden": true },
            { "type": "chore", "section": "í·ą Maintenance", "hidden": true },
            { "type": "revert", "section": "âŹŞ Reverts", "hidden": false }
          ]
        }
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    ["@semantic-release/npm", { "npmPublish": false }],
    ["@semantic-release/npm", { "npmPublish": false, "pkgRoot": "apps/tauri" }],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "node scripts/sync-tauri-version.mjs ${nextRelease.version}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": "íľ‰ This is included in version ${nextRelease.version}.",
        "failComment": false,
        "addReleases": "bottom"
      }
    ]
  ]
}
