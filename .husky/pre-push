#!/usr/bin/env sh
# Runs before `git push`.
#
# Quality gate mirroring CI, but PATH-FILTERED to the files actually being pushed
# (the local analogue of CI's dorny/paths-filter). A docs-only or JS-only push
# skips the Rust/cargo steps entirely — so it can't hit the ajh-tauri.exe build
# lock — and a Rust-only push skips the JS gate. The filter groups match CI's
# `frontend`/`rust` filters in .github/workflows/ci-pipeline.yml.
#
# Safety: on ANY uncertainty (no push range, detached state) it falls back to the
# FULL gate, and cross-cutting paths (packages/**, .github/**) trip both groups.
# Force the full gate with PREPUSH_FULL=1. CI remains the authoritative gate;
# this is just a fast local pre-check.

set -e

if [ -n "$GITHUB_ACTIONS" ]; then
  exit 0
fi

GIT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_ROOT" || exit 1

# ── Sync with origin/main before pushing ───────────────────────────────────────
# Never push a branch built on a stale base — that is what lets a PR look clean
# locally yet surface merge conflicts on GitHub. Fetch origin/main and, when the
# branch is behind, fold it in first. A pre-push hook can't add the merge commit
# to the in-flight push (git already fixed the payload), so on a clean merge we
# stop and ask for a re-push; on conflicts we abort and let the dev resolve.
# Skipped on main itself, in detached HEAD, when offline, or with PREPUSH_NO_SYNC=1.
if [ -z "${PREPUSH_NO_SYNC:-}" ]; then
  branch=$(git symbolic-ref --short -q HEAD || true)
  if [ -n "$branch" ] && [ "$branch" != "main" ]; then
    if git fetch -q origin main 2>/dev/null; then
      if [ -n "$(git rev-list -n1 FETCH_HEAD --not "$branch" 2>/dev/null)" ]; then
        # A dirty tree makes `git merge` refuse before it even starts, so handle
        # it explicitly — otherwise the abort no-ops and the conflict message
        # below would misleadingly blame a content conflict.
        if ! git diff-index --quiet HEAD -- 2>/dev/null; then
          echo "✗ origin/main has new commits but your working tree is dirty — commit or stash, then push again."
          exit 1
        fi
        echo "↻ origin/main has new commits — merging into $branch before push..."
        if git merge --no-edit FETCH_HEAD; then
          echo "✓ Merged latest origin/main into $branch."
          echo "✗ Re-run your push so the merge commit is included."
          exit 1
        else
          git merge --abort 2>/dev/null || true
          echo "✗ Could not cleanly merge origin/main — resolve the conflicts, commit, then push again."
          exit 1
        fi
      fi
    else
      echo "⚠ Could not fetch origin/main (offline?) — pushing without a fresh main sync."
    fi
  fi
fi

# Never use the turbo cache on push: a cached PASS can hide a real failure that
# only surfaces on a clean run. Force every turbo task to execute.
export TURBO_FORCE=1

# ── Determine the changed-file set for this push ───────────────────────────────
# Git feeds the refs being pushed on stdin, one per line:
#   "<local_ref> <local_sha> <remote_ref> <remote_sha>"
# Diff remote_sha..local_sha per ref; for a brand-new branch (remote all-zeros)
# diff against the merge-base with origin/main. Any failure → FULL gate.
ZERO=0000000000000000000000000000000000000000
CHANGED=""
RANGES=""
HAVE_RANGE=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ -z "${local_sha:-}" ] || [ "$local_sha" = "$ZERO" ]; then
    continue # nothing to push on this ref (or a branch deletion)
  fi
  if [ "${remote_sha:-$ZERO}" = "$ZERO" ]; then
    base=$(git merge-base origin/main "$local_sha" 2>/dev/null || git rev-parse origin/main 2>/dev/null || true)
    if [ -z "$base" ]; then
      HAVE_RANGE=0
      CHANGED=""
      break # can't establish a base → force the full gate below
    fi
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  files=$(git diff --name-only "$range" 2>/dev/null || true)
  RANGES="$RANGES $range"
  CHANGED="$CHANGED
$files"
  HAVE_RANGE=1
done

# ── Docs / meta fast path ──────────────────────────────────────────────────────
# When the branch's OWN contribution (merge-base(origin/main)..HEAD — what this PR
# actually adds, NOT the raw push range) is entirely docs/meta content, the heavy
# build/typecheck/test/rust gates add nothing: markdown, docs/**, the .claude
# agent/skill/command fleet, CLAUDE.md and apps/landing/*.html are never built or run.
# Using the branch's own diff (not remote_sha..local_sha) means a re-push that only
# folds a fresh origin/main in — exactly what the sync step above forces on a stale
# PR — still fast-paths a docs-only PR instead of re-gating main's already-merged,
# already-tested code. Run ONLY the cheap guards those paths need, then exit.
#
# Safety: ANY executable/config/build input (.husky/**, .claude/hooks/**,
# .claude/settings*, scripts/**, package.json, lockfiles, tsconfig, *.config.*,
# Cargo.*, .github/**, or any *.rs/*.mjs/*.ts/*.sh/…) drops straight to the full
# gate below — as does PREPUSH_FULL=1, an undetermined push range (HAVE_RANGE=0),
# or an unresolvable merge-base. Uncertainty always takes the full gate.
if [ -z "${PREPUSH_FULL:-}" ] && [ "$HAVE_RANGE" -eq 1 ]; then
  own_base=$(git merge-base origin/main HEAD 2>/dev/null || true)
  own_files=""
  if [ -n "$own_base" ]; then
    own_files=$(git diff --name-only "$own_base..HEAD" 2>/dev/null | grep -E '.' || true)
  fi
  # ALLOW: every changed file is plainly non-executable docs/meta content.
  # apps/landing/public/*.html = passthrough dashboards (never built); the routes'
  # authored bodies live under src/content and are NOT docs (they affect the build).
  DOCS_ALLOW='\.(md|mdx|txt)$|^docs/|^\.claude/(agents|skills|commands)/|^apps/landing/public/.*\.html$'
  # DENY: executable/config/build inputs — even when they sit under an allowed dir.
  DOCS_DENY='\.(mjs|cjs|jsx?|tsx?|mts|cts|rs|sh|bash|zsh|ps1|bat|cmd|py|rb)$|^\.husky/|^\.claude/hooks/|^\.claude/settings|^scripts/|(^|/)package(-lock)?\.json$|pnpm-lock\.yaml$|(^|/)tsconfig[^/]*\.json$|(^|/)Cargo\.(toml|lock)$|\.config\.(js|mjs|cjs|ts)$|^\.github/'
  if [ -n "$own_files" ] \
    && ! printf '%s\n' "$own_files" | grep -qvE "$DOCS_ALLOW" \
    && ! printf '%s\n' "$own_files" | grep -qE "$DOCS_DENY"; then
    n=$(printf '%s\n' "$own_files" | grep -c .)
    echo "▶ Path filter: DOCS/META fast path (${n} files — branch is docs/meta only; skipping build/typecheck/test + rust + AI review). PREPUSH_FULL=1 forces the full gate."
    if printf '%s\n' "$own_files" | grep -qE '^\.claude/|^CLAUDE\.md$'; then
      echo "▶ Checking agent-system drift..."
      node scripts/check-agent-system.mjs
    fi
    if printf '%s\n' "$own_files" | grep -qE '^apps/landing/'; then
      echo "▶ Checking landing-diagram drift..."
      pnpm check:landing-drift
    fi
    echo "▶ Prettier-checking changed docs..."
    printf '%s\n' "$own_files" | xargs pnpm exec prettier --check --ignore-unknown
    echo "✓ Docs/meta fast path complete"
    exit 0
  fi
fi

RUST=""
NODE=""
LANDING=""
WORKFLOWS=""
if [ -n "${PREPUSH_FULL:-}" ] || [ "$HAVE_RANGE" -eq 0 ]; then
  RUST=1
  NODE=1
  LANDING=1
  WORKFLOWS=1
  if [ -n "${PREPUSH_FULL:-}" ]; then
    echo "▶ Path filter: FULL gate (PREPUSH_FULL set)"
  else
    echo "▶ Path filter: FULL gate (push range undetermined)"
  fi
else
  if printf '%s\n' "$CHANGED" | grep -qE '^apps/desktop/src-tauri/|(^|/)Cargo\.(toml|lock)$|\.rs$|^\.github/'; then
    RUST=1
  fi
  if printf '%s\n' "$CHANGED" | grep -qE '^apps/desktop/src/|^packages/|^package\.json$|^pnpm-lock\.yaml$|^tsconfig.*\.json$|^eslint\.config\.mjs$|^vitest\.config\.ts$|^turbo\.json$|^\.github/'; then
    NODE=1
  fi
  if printf '%s\n' "$CHANGED" | grep -qE '^apps/landing/'; then
    LANDING=1
  fi
  if printf '%s\n' "$CHANGED" | grep -qE '^\.github/workflows/'; then
    WORKFLOWS=1
  fi
  count=$(printf '%s\n' "$CHANGED" | grep -c . || true)
  echo "▶ Path filter: NODE=${NODE:-0} RUST=${RUST:-0} LANDING=${LANDING:-0} WORKFLOWS=${WORKFLOWS:-0} (${count} files changed)"
  if [ -z "$RUST" ] && [ -z "$NODE" ] && [ -z "$LANDING" ]; then
    echo "✓ No gated paths changed — skipping the build/test gate."
  fi
fi

# ── Node / frontend gate (CI `frontend` filter) ────────────────────────────────
if [ -n "$NODE" ]; then
  echo "▶ Building shared packages..."
  pnpm build:packages

  echo "▶ Running ESLint strict..."
  pnpm lint:strict

  echo "▶ Checking formatting..."
  pnpm format:check

  echo "▶ Running TypeScript type check..."
  pnpm typecheck --force

  echo "▶ Running package tests..."
  pnpm test
fi

# ── IPC codegen drift ──────────────────────────────────────────────────────────
# Schemas live in packages/shared (node) and the generated output in src-tauri
# (rust), so run it whenever either group is in play.
if [ -n "$NODE" ] || [ -n "$RUST" ]; then
  echo "▶ Checking IPC codegen drift..."
  pnpm gen:ipc:check
fi

# ── Landing-diagram drift ──────────────────────────────────────────────────────
# The apps/landing architecture/how-it-works diagrams are derived from the code, so a
# change to the diagrammed source (node/rust) OR to the landing pages can drift.
if [ -n "$NODE" ] || [ -n "$RUST" ] || [ -n "$LANDING" ]; then
  echo "▶ Checking landing-diagram drift..."
  pnpm check:landing-drift
fi

# ── Landing copy/link parity ────────────────────────────────────────────────────
# The Next landing port must not silently drop a legacy link or signature joke.
# Build the static export and assert parity against out/. Only when the landing
# source actually changed (LANDING) — the build is landing-scoped.
if [ -n "$LANDING" ]; then
  echo "▶ Building landing + checking copy/link parity..."
  pnpm --filter @ajh/landing build
  pnpm --filter @ajh/landing check:parity
fi

# ── Workflow-catalog drift ─────────────────────────────────────────────────────
# The generated .github/workflows/README.md (+ README badges) is derived from the
# workflow files; regenerate and fail if it drifted. Only when a workflow changed
# (CI's "Workflow Catalog" job is authoritative — this catches it before the push).
if [ -n "$WORKFLOWS" ]; then
  echo "▶ Checking workflow-catalog drift..."
  pnpm gen:workflows:check
fi

# ── Agent-system drift ─────────────────────────────────────────────────────────
# Keeps the .claude/ agent fleet + its docs + the other AI-tool configs in sync.
# Validates whole-system state (not diff-based), so run it unconditionally as a
# backstop. Invoke node directly (not `pnpm run`) to skip pnpm's startup overhead.
echo "▶ Checking agent-system drift..."
node scripts/check-agent-system.mjs

# ── Rust gate (CI `rust` filter) ───────────────────────────────────────────────
if [ -n "$RUST" ]; then
  cd apps/desktop/src-tauri

  echo "▶ Running cargo check..."
  cargo check --all-targets --all-features --locked

  if [ -n "${AJH_SKIP_CARGO_TEST:-}" ]; then
    echo "⚠ AJH_SKIP_CARGO_TEST=1 — skipping ONLY cargo test (known host DLL fault). CI still runs it."
  else
    echo "▶ Running Rust tests (incl. architecture boundary tests)..."
    test_out=$(cargo test --all-features --locked 2>&1) || {
      if printf '%s' "$test_out" | grep -qi "STATUS_ENTRYPOINT_NOT_FOUND\|0xc0000139"; then
        echo "⚠ cargo test hit the known host entrypoint fault — skipping ONLY cargo test; check/clippy/fmt/deny still run. CI remains authoritative."
      else
        printf '%s\n' "$test_out"
        exit 1
      fi
    }
  fi

  echo "▶ Running Rust clippy..."
  cargo clippy --all-targets --all-features --locked -- -D warnings

  echo "▶ Checking Rust formatting..."
  cargo fmt --all -- --check

  # Supply-chain + unused-dependency gates. CI runs these unconditionally; locally
  # they are best-effort — skipped with a hint if the tool isn't installed, so the
  # hook never blocks a dev who hasn't run the one-time `cargo install`.
  if command -v cargo-deny >/dev/null 2>&1; then
    echo "▶ Running cargo-deny..."
    cargo deny check
  else
    echo "⚠ cargo-deny not installed — skipping (CI enforces it). Install: cargo install cargo-deny --locked"
  fi

  if command -v cargo-machete >/dev/null 2>&1; then
    echo "▶ Running cargo-machete..."
    cargo machete
  else
    echo "⚠ cargo-machete not installed — skipping (CI enforces it). Install: cargo install cargo-machete"
  fi

  cd "$GIT_ROOT"
fi

# ── AI review of the push range (ADR-0008) ─────────────────────────────────────
# Deterministic findings (ast-grep) block from day one; LLM findings are in
# RATCHET warn mode (REVIEW_MODE=block to enforce). REVIEW_SKIP=1 skips but is
# AUDITED in .claude/.review-metrics.jsonl — prefer it over --no-verify, which
# silently skips this whole gate.
if [ -n "${REVIEW_SKIP:-}" ]; then
  echo "⚠ REVIEW_SKIP=1 — AI pre-push review skipped (audited)."
  PREPUSH_RANGES="$RANGES" node scripts/pre-push-review.mjs --log-skip || true
else
  echo "▶ AI review of push range..."
  PREPUSH_RANGES="$RANGES" node scripts/pre-push-review.mjs
fi

echo "✓ Pre-push gate complete"