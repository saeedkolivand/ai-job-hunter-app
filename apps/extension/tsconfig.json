{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // WebExtension surface: DOM (content script + popup + SW WebSocket) plus the
    // `chrome` global (@types/chrome). The `browser` namespace comes from the
    // @wxt-dev/browser module import, not an ambient type. NOT the Node renderer
    // toolchain — no `@types/node`, no React DOM project types.
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "types": ["chrome"],
    "noEmit": true,
    "rootDir": ".",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "vitest.config.ts", "vitest.setup.ts"]
}
