{
  "name": "ai-job-hunter-desktop",
  "private": true,
  "version": "0.118.2",
  "description": "AI Job Hunter — local-first, AI-native desktop application",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm build:packages && cargo fetch --manifest-path apps/tauri/src-tauri/Cargo.toml && pnpm --filter @ajh/tauri dev",
    "build": "turbo build",
    "build:packages": "turbo build --filter=!@ajh/tauri",
    "build:chrome": "pnpm --filter @ajh/extension build:chrome",
    "build:firefox": "pnpm --filter @ajh/extension build:firefox",
    "package": "pnpm build:packages && pnpm --filter @ajh/tauri package",
    "typecheck": "turbo typecheck",
    "lint": "eslint .",
    "lint:strict": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "gen:ipc": "pnpm --filter @ajh/shared gen:ipc",
    "gen:ipc:check": "pnpm --filter @ajh/shared gen:ipc:check",
    "gen:workflows": "node scripts/gen-workflow-catalog.mjs && prettier --write .github/workflows/README.md README.md",
    "gen:workflows:check": "node scripts/gen-workflow-catalog.mjs && prettier --write .github/workflows/README.md README.md && git diff --exit-code -- .github/workflows/README.md README.md",
    "check:landing-drift": "node scripts/check-landing-drift.mjs",
    "check:agent-system": "node scripts/check-agent-system.mjs",
    "clean": "pnpm -r exec rimraf dist out .turbo node_modules/.cache",
    "clean:turbo": "pnpm -r exec rimraf .turbo node_modules/.cache/turbo",
    "storybook": "pnpm --filter @ajh/ui storybook",
    "build-storybook": "pnpm --filter @ajh/ui build-storybook",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.8",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "knip": "^6.18.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.5",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
