{
  "mcpServers": {
    "graphify": {
      "command": "node",
      "args": ["scripts/graphify-mcp.mjs"]
    },
    "codegraph": {
      "type": "stdio",
      "command": "codegraph",
      "args": ["serve", "--mcp"]
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
